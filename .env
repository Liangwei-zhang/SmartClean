# SmartClean 環境變量配置示例
# 複製為 .env 並填入實際值

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartclean
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/smartclean

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# S3 / Object Storage (可選)
# 啟用 S3 存儲
S3_ENABLED=false

# S3 端點 (AWS S3 可以留空，使用默認)
# AWS: https://s3.amazonaws.com
# Aliyun OSS: https://oss-cn-hangzhou.aliyuncs.com
# MinIO: http://localhost:9000
S3_ENDPOINT_URL=

# S3 訪問憑證
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# S3 Bucket 名稱
S3_BUCKET=smartclean

# S3 Region
S3_REGION=us-east-1

# CDN URL (可選，如果使用 CloudFlare/CloudFront CDN)
S3_PUBLIC_URL=

# Custom
X_BEARER_TOKEN=your_bearer_token_here
NICO_TELEGRAM_ID=
