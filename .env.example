# SmartClean 環境變量 — 複製為 .env 並填入真實值
# 警告：.env 文件絕對不能提交到版本控制！

# ── 資料庫 ────────────────────────────────────────────────────────────────────
DB_USER=smartclean
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@pgbouncer:5432/smartclean
DATABASE_URL_SYNC=postgresql://${DB_USER}:${DB_PASSWORD}@pgbouncer:5432/smartclean

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────────────────────────
# 逗號分隔，例: https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=

# ── 上傳 ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── S3 / Object Storage (可選) ────────────────────────────────────────────────
S3_ENABLED=false
# AWS S3: https://s3.amazonaws.com
# Aliyun OSS: https://oss-cn-hangzhou.aliyuncs.com
# MinIO: http://minio:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=smartclean
S3_REGION=us-east-1
S3_PUBLIC_URL=

# ── 其他 ─────────────────────────────────────────────────────────────────────
X_BEARER_TOKEN=
